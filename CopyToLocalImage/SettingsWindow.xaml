<Window x:Class="CopyToLocalImage.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置"
        Height="450" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource PrimaryBackground}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <!-- 保存路径 -->
            <TextBlock Text="图片保存路径" FontWeight="Bold" Margin="0,0,0,8" />
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="SavePathTextBox"
                         Height="30"
                         VerticalContentAlignment="Center"
                         Margin="0,0,8,0" />
                <Button x:Name="BrowseButton"
                        Grid.Column="1"
                        Content="浏览..."
                        Width="80"
                        Click="BrowseButton_Click" />
            </Grid>

            <!-- 关闭行为 -->
            <TextBlock Text="关闭行为" FontWeight="Bold" Margin="0,16,0,8" />
            <CheckBox x:Name="MinimizeToTrayCheckBox"
                      Content="关闭窗口时最小化到系统托盘"
                      Margin="0,0,0,16"
                      IsChecked="True" />

            <!-- 启动行为 -->
            <CheckBox x:Name="StartMinimizedCheckBox"
                      Content="启动时自动最小化到托盘"
                      Margin="0,0,0,16" />

            <!-- 全局热键 -->
            <TextBlock Text="全局热键" FontWeight="Bold" Margin="0,16,0,8" />
            <CheckBox x:Name="EnableHotkeyCheckBox"
                      Content="启用全局热键"
                      Margin="0,0,0,8"
                      IsChecked="True" />
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="快捷键：" VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBox x:Name="HotkeyTextBox"
                         Grid.Column="1"
                         Height="30"
                         VerticalContentAlignment="Center"
                         Text="Ctrl+Alt+V" />
            </Grid>

            <!-- 自动清理 -->
            <TextBlock Text="自动清理" FontWeight="Bold" Margin="0,16,0,8" />
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="保留天数：" VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBox x:Name="AutoCleanDaysTextBox"
                         Grid.Column="1"
                         Height="30"
                         VerticalContentAlignment="Center"
                         Text="0" />
            </Grid>
            <TextBlock Text="设置为 0 表示不自动清理"
                       FontSize="12"
                       Foreground="{StaticResource SecondaryText}" />

            <!-- 主题 -->
            <TextBlock Text="主题" FontWeight="Bold" Margin="0,16,0,8" />
            <CheckBox x:Name="DarkThemeCheckBox"
                      Content="使用深色主题"
                      Margin="0,0,0,8" />
        </StackPanel>

        <!-- 按钮 -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <Button x:Name="SaveButton"
                    Style="{StaticResource PrimaryButton}"
                    Content="保存"
                    Width="80"
                    Margin="0,0,8,0"
                    Click="SaveButton_Click" />
            <Button x:Name="CancelButton"
                    Style="{StaticResource SecondaryButton}"
                    Content="取消"
                    Width="80"
                    Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</Window>
