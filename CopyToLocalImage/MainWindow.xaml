<Window x:Class="CopyToLocalImage.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:CopyToLocalImage.Converters"
        Title="CopyToLocalImage - 图片剪切板监听"
        Height="600" Width="900"
        WindowStyle="SingleBorderWindow"
        Background="{StaticResource PrimaryBackground}"
        Closing="Window_Closing">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <Border Grid.Row="0" Background="{StaticResource SecondaryBackground}" Padding="16,12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- 视图切换和设置 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <ToggleButton x:Name="GridViewButton"
                                  Style="{StaticResource ViewToggleButton}"
                                  Content="📊 网格"
                                  IsChecked="True"
                                  Click="GridViewButton_Click" />
                    <ToggleButton x:Name="ListViewButton"
                                  Style="{StaticResource ViewToggleButton}"
                                  Content="📋 列表"
                                  Margin="8,0,0,0"
                                  Click="ListViewButton_Click" />
                    <Button x:Name="SettingsButton"
                            Style="{StaticResource SecondaryButton}"
                            Content="⚙️ 设置"
                            Margin="16,0,0,0"
                            Click="SettingsButton_Click" />
                </StackPanel>

                <!-- 窗口控制 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="MinimizeButton"
                            Style="{StaticResource SecondaryButton}"
                            Content="_" Width="30" Padding="0"
                            Click="MinimizeButton_Click" />
                    <Button x:Name="CloseButton"
                            Style="{StaticResource SecondaryButton}"
                            Content="✕" Width="30" Padding="0"
                            Margin="8,0,0,0"
                            Click="CloseButton_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- 筛选工具栏 -->
        <Border Grid.Row="1" Background="{StaticResource PrimaryBackground}" Padding="16,12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="筛选：" VerticalAlignment="Center" Margin="0,0,12,0" />

                <ComboBox Grid.Column="1" x:Name="FilterComboBox"
                          Style="{StaticResource FilterComboBox}"
                          Width="120"
                          SelectionChanged="FilterComboBox_SelectionChanged">
                    <ComboBoxItem Content="全部" IsSelected="True" />
                    <ComboBoxItem Content="今天" />
                    <ComboBoxItem Content="本周" />
                    <ComboBoxItem Content="本月" />
                </ComboBox>

                <StackPanel Grid.Column="3" Orientation="Horizontal">
                    <Button x:Name="SelectAllButton"
                            Style="{StaticResource SecondaryButton}"
                            Content="全选"
                            Margin="0,0,8,0"
                            Click="SelectAllButton_Click" />
                    <Button x:Name="DeleteSelectedButton"
                            Style="{StaticResource DangerButton}"
                            Content="🗑 删除选中"
                            Click="DeleteSelectedButton_Click" />
                    <Button x:Name="DeleteOldDataButton"
                            Style="{StaticResource SecondaryButton}"
                            Content="🗓 按日期删除"
                            Margin="8,0,0,0"
                            Click="DeleteOldDataButton_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- 图片列表区域 -->
        <Grid Grid.Row="2" Margin="16">
            <!-- 网格视图 -->
            <ListBox x:Name="GridViewListBox"
                     AllowDrop="True"
                     DragOver="ListBox_DragOver"
                     Drop="ListBox_Drop"
                     PreviewMouseMove="ListBox_PreviewMouseMove"
                     SelectionMode="Extended"
                     ItemContainerStyle="{StaticResource ImageListBoxItem}"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling">
                <ListBox.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="打开文件位置" Click="OpenFileLocationMenuItem_Click" />
                        <MenuItem Header="在资源管理器中显示" Click="ShowInExplorerMenuItem_Click" />
                        <Separator />
                        <MenuItem Header="删除" Click="DeleteMenuItem_Click" />
                    </ContextMenu>
                </ListBox.ContextMenu>
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.Template>
                    <ControlTemplate TargetType="ListBox">
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto"
                                      CanContentScroll="True">
                            <ItemsPresenter />
                        </ScrollViewer>
                    </ControlTemplate>
                </ListBox.Template>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border x:Name="ImageBorder" Width="180" Height="240"
                                Background="{StaticResource SecondaryBackground}"
                                CornerRadius="8" Margin="4" Padding="8"
                                BorderThickness="2"
                                BorderBrush="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=inverse}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="BorderBrush" Value="{StaticResource AccentColor}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Border.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             From="0" To="1" Duration="0:0:0.3" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Border.Triggers>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="140" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <!-- 缩略图 -->
                                <Border Grid.Row="0"
                                        Background="{StaticResource TertiaryBackground}"
                                        CornerRadius="4"
                                        Margin="0,0,0,4"
                                        ClipToBounds="True">
                                    <Image Source="{Binding FilePath, Converter={StaticResource FilePathToImageConverter}}"
                                           Stretch="Uniform"
                                           Margin="4">
                                        <Image.ToolTip>
                                            <TextBlock Text="{Binding FilePath}" />
                                        </Image.ToolTip>
                                    </Image>
                                </Border>

                                <!-- 文件名 -->
                                <Border Grid.Row="1"
                                        Background="{StaticResource SelectionBackground}"
                                        CornerRadius="4"
                                        Margin="0,4"
                                        Padding="4,2">
                                    <TextBlock Text="{Binding FilePath, Converter={StaticResource FileNameConverter}}"
                                               FontSize="11"
                                               FontWeight="Bold"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding FilePath}" />
                                </Border>

                                <!-- 信息 -->
                                <StackPanel Grid.Row="2">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="DateText"
                                                   Text="{Binding DateString}"
                                                   FontSize="12"
                                                   FontWeight="Bold" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding FileSizeDisplay}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource SecondaryText}" />
                                    </Grid>
                                    <TextBlock FontSize="11"
                                               Foreground="{StaticResource SecondaryText}">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0}x{1}">
                                                <Binding Path="Width" />
                                                <Binding Path="Height" />
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding DateString}" Value="{x:Null}">
                                <Setter TargetName="DateText" Property="Text" Value="未知日期" />
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- 列表视图 -->
            <ListBox x:Name="ListViewListBox"
                     AllowDrop="True"
                     DragOver="ListBox_DragOver"
                     Drop="ListBox_Drop"
                     PreviewMouseMove="ListBox_PreviewMouseMove"
                     SelectionMode="Extended"
                     ItemContainerStyle="{StaticResource ImageListBoxItem}"
                     Visibility="Collapsed"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling">
                <ListBox.Template>
                    <ControlTemplate TargetType="ListBox">
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto"
                                      CanContentScroll="True">
                            <ItemsPresenter />
                        </ScrollViewer>
                    </ControlTemplate>
                </ListBox.Template>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border x:Name="ListBorder" Background="{StaticResource SecondaryBackground}"
                                CornerRadius="4" Margin="2,4" Padding="8">
                            <Border.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             From="0" To="1" Duration="0:0:0.2" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Border.Triggers>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="150" />
                                </Grid.ColumnDefinitions>

                                <!-- 缩略图 -->
                                <Border Grid.Column="0"
                                        Background="{StaticResource TertiaryBackground}"
                                        CornerRadius="4"
                                        Margin="0,0,8,0">
                                    <Image Source="{Binding FilePath, Converter={StaticResource FilePathToImageConverter}}"
                                           Stretch="Uniform"
                                           Margin="4" />
                                </Border>

                                <!-- 日期 -->
                                <TextBlock Grid.Column="1"
                                           Text="{Binding DateString}"
                                           VerticalAlignment="Center"
                                           FontWeight="Bold" />

                                <!-- 文件大小 -->
                                <TextBlock Grid.Column="2"
                                           Text="{Binding FileSizeDisplay}"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource SecondaryText}" />

                                <!-- 尺寸 -->
                                <TextBlock Grid.Column="3"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource SecondaryText}">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0}x{1}">
                                            <Binding Path="Width" />
                                            <Binding Path="Height" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>

                                <!-- 时间 -->
                                <TextBlock Grid.Column="4"
                                           Text="{Binding CreatedAt, StringFormat={}{0:HH:mm:ss}}"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource SecondaryText}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- 空状态提示 -->
            <TextBlock x:Name="EmptyTextBlock"
                       Text="暂无图片&#10;&#10;复制图片到剪切板即可自动保存"
                       FontSize="16"
                       Foreground="{StaticResource SecondaryText}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       TextAlignment="Center" />
        </Grid>
    </Grid>
</Window>
